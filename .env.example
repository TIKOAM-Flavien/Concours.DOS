# Server-only secrets and integrations
PORT=3001
NODE_ENV=production

# Runtime role: all (monolith dev), admin (internal), portal (DMZ)
PORTAL_APP_ROLE=all

# Dedicated pepper for hashing actor IPs in the audit log. Use a strong, random
# value (>=32 bytes). Optional: if absent, falls back to PORTAL_LINK_SECRET, but
# rotating the link secret then invalidates historical IP hashes.
# PORTAL_IP_HASH_PEPPER=

# PostgreSQL (required)
# In Docker-compose deployments these three variables drive both the postgres
# container init and the DATABASE_URL injected into the admin/portal services.
# Keep them out of version control (.env.production is gitignored).
POSTGRES_USER=portail
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=portail
DATABASE_URL=postgresql://portail:replace-with-a-strong-db-password@localhost:5432/portail

# Signing + invitation links
# Generate a long random value, e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
PORTAL_LINK_SECRET=replace-with-a-long-random-secret
# Default link validity in minutes (30 days). Clamped by PORTAL_LINK_TTL_MAX_MINUTES.
PORTAL_LINK_TTL_MINUTES=43200
# Hard ceiling accepted by POST /api/admin/invitations/sign. Defaults to 1 year.
PORTAL_LINK_TTL_MAX_MINUTES=525600
# Admin only: public URL embedded in signed invitation links (external portal domain).
CLIENT_PORTAL_PUBLIC_URL=https://portal.example.com/depot

# Upload sizing. PORTAL_MAX_FILE_MB is enforced on multipart file uploads.
# PORTAL_MAX_BODY_MB remains the JSON body limit for non-file API calls.
PORTAL_MAX_FILE_MB=20
PORTAL_MAX_BODY_MB=5
# Portal only: fichiers stockes localement sur le VPS.
PORTAL_UPLOAD_STAGING_DIR=/data/uploads
PORTAL_UPLOAD_RETENTION_DAYS=14
PORTAL_UPLOAD_JOB_MAX_ATTEMPTS=5

# Limite d'espace disque "logique" (affichage admin). Utile quand Docker a un quota volume.
# Par defaut: 15 Go si non configure.
# PORTAL_STORAGE_QUOTA_GB=15
# PORTAL_STORAGE_QUOTA_BYTES=16106127360

# Rate limiting (in-memory; use a shared store for multi-instance portal deployments).
PORTAL_RATE_LIMIT_PER_MINUTE=60
PORTAL_UPLOAD_RATE_LIMIT_PER_MINUTE=10
# Budget journalier par soumission (debite apres depot / telechargement / suppression reussi).
PORTAL_SUBMISSION_DAILY_BUDGET=300
# Delai max des appels Power Automate (flows mail uniquement).
PORTAL_FLOW_TIMEOUT_MS=120000

# Admin authentication (password login + signed session cookie)
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
PORTAL_ADMIN_USERNAME=admin
PORTAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password
# PORTAL_ADMIN_SESSION_SECRET=optional-dedicated-session-secret
# PORTAL_ADMIN_SESSION_TTL_HOURS=12

# Reverse-proxy trust. Set to "loopback", "uniquelocal", a comma-separated list
# of trusted IPs/CIDRs, or a positive integer hop count. Leave empty when the
# server is directly exposed. In Docker behind nginx/NPM, "uniquelocal" is
# usually the safest pick (RFC1918 + loopback).
TRUST_PROXY=

# Admin UI + /api/admin* (no separate login): by default only loopback clients.
# Behind Docker/nginx, configure TRUST_PROXY then optionally allow fixed egress IPs.
# Accepts single IPv4 entries and CIDR ranges, comma-separated:
# PORTAL_ADMIN_ALLOWED_IPS=203.0.113.10,198.51.100.0/24
PORTAL_ADMIN_ALLOWED_IPS=

# HSTS (Strict-Transport-Security). On by default when NODE_ENV=production.
PORTAL_FORCE_HSTS=
PORTAL_HSTS_MAX_AGE=31536000
PORTAL_HSTS_INCLUDE_SUBDOMAINS=true
PORTAL_HSTS_PRELOAD=false

# Power Automate — flows mail uniquement (documents = stockage local VPS)
POWER_AUTOMATE_SEND_INVITATIONS_URL=https://example.powerautomate/.../send-invitations
POWER_AUTOMATE_SEND_REMINDERS_URL=https://example.powerautomate/.../send-reminders

# Safe public frontend branding/config only
# Optional — defaults to package.json version at build time (shown in UI as v1.0.0).
# VITE_APP_VERSION=1.0.0

VITE_CLIENT_PORTAL_ORGANIZATION=TIKOAM
VITE_CLIENT_PORTAL_TITLE=Plateforme de depot de pieces concours
VITE_CLIENT_PORTAL_SUBTITLE=Deposez les pieces administratives demandees pour votre candidature.
VITE_CLIENT_PORTAL_SUPPORT_EMAIL=contact@example.com
VITE_CLIENT_PORTAL_SUPPORT_PHONE=+33 1 23 45 67 89
VITE_CLIENT_PORTAL_WEBSITE_URL=https://www.example.com
VITE_CLIENT_PORTAL_MAX_FILE_MB=20
VITE_CLIENT_PORTAL_DEFAULT_FOLDER_PATH=/depots/concours-exemple
VITE_CLIENT_PORTAL_DEFAULT_DOSSIER_ID=BDD_reception_piece
VITE_CLIENT_PORTAL_CONTEST_NAME=Concours exemple
VITE_CLIENT_PORTAL_REQUIRED_DOCUMENTS=KBIS,URSSAF,RIB,ASSURANCE_RC
